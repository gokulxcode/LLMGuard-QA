# LLMGuard QA Environment Variables

# API Settings
PORT=8000
HOST=0.0.0.0

# Security
JWT_SECRET=super_secret_llm_guard_qa_jwt_token_key_change_me_in_production_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
# Default to SQLite for zero-config startup. Replace with MySQL connection string as needed:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/llmguard_qa
DATABASE_URL=sqlite:///./llmguard_qa.db

# Gemini API Integration
# User can replace this with their actual Gemini API key.
# If empty, the backend will run in evaluation mockup mode with realistic data so the app is fully browsable.
GEMINI_API_KEY=

# Initial Admin User (created on first launch)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@llmguard.qa
ADMIN_PASSWORD=adminpassword
